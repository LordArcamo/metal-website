---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StoreLocator from '../components/StoreLocator.tsx';
---

<Layout
  title="Find a Store — 130+ Locations Across US, Canada & UK"
  description="Find your nearest Metal Supermarkets. 80+ US locations, 30+ Canada, 20+ UK. Walk in same day for cut-to-size metal. No appointment needed."
  keywords="metal supermarkets locations, find a metal store, metal store near me, metal supplier near me"
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="loc-hero">
      <div class="loc-hero-bg"></div>
      <div class="container">
        <div class="loc-hero-inner">
          <span class="section-label">Store Locator</span>
          <div class="divider"></div>
          <h1 class="display-xl loc-hero-title">
            130+ Stores.<br />
            <span class="loc-title-accent">Near You.</span>
          </h1>
          <p class="loc-hero-sub">
            Across the US, Canada, and the UK — walk in, get your metal cut to size, walk out.
            Same day. No appointment needed.
          </p>
          <!-- Country count pills -->
          <div class="loc-hero-pills">
            <div class="loc-pill">
              <span class="loc-pill-flag">🇺🇸</span>
              <span class="loc-pill-count">80+</span>
              <span class="loc-pill-label">US Stores</span>
            </div>
            <div class="loc-pill-divider"></div>
            <div class="loc-pill">
              <span class="loc-pill-flag">🇨🇦</span>
              <span class="loc-pill-count">30+</span>
              <span class="loc-pill-label">Canada</span>
            </div>
            <div class="loc-pill-divider"></div>
            <div class="loc-pill">
              <span class="loc-pill-flag">🇬🇧</span>
              <span class="loc-pill-count">20+</span>
              <span class="loc-pill-label">UK Stores</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Walk-in banner -->
    <div class="loc-banner">
      <div class="container loc-banner-inner">
        <div class="loc-banner-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Mon–Fri, 7:30am–5pm</span>
        </div>
        <div class="loc-banner-divider"></div>
        <div class="loc-banner-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          <span>Walk-in Welcome — No Appointment</span>
        </div>
        <div class="loc-banner-divider"></div>
        <div class="loc-banner-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Same-Day Cut-to-Size Service</span>
        </div>
        <div class="loc-banner-divider"></div>
        <div class="loc-banner-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <a href="tel:18883179980" class="loc-banner-link">1-888-317-9980</a>
        </div>
      </div>
    </div>

    <!-- Store Locator Component -->
    <section class="loc-section">
      <div class="container">
        <StoreLocator client:load />
      </div>
    </section>

    <!-- Franchise CTA -->
    <section class="loc-franchise">
      <div class="container">
        <div class="loc-franchise-inner reveal">
          <div class="loc-franchise-text">
            <span class="section-label">Don't See Your City?</span>
            <div class="divider"></div>
            <h2 class="display-md">A New Store May Be Opening Near You</h2>
            <p class="loc-franchise-sub">
              Metal Supermarkets is actively expanding. New franchise locations open every year
              across North America and the UK. Check back soon — or become an owner yourself.
            </p>
            <div class="loc-franchise-actions">
              <a href="/franchise" class="btn btn-primary">Learn About Franchising</a>
              <a href="/contact" class="btn btn-outline">Contact Us</a>
            </div>
          </div>
          <div class="loc-franchise-stats">
            <div class="loc-stat">
              <div class="loc-stat-value">$2.1M</div>
              <div class="loc-stat-label">Avg Annual Sales</div>
            </div>
            <div class="loc-stat">
              <div class="loc-stat-value">50%+</div>
              <div class="loc-stat-label">Avg Gross Margin</div>
            </div>
            <div class="loc-stat">
              <div class="loc-stat-value">40+</div>
              <div class="loc-stat-label">Years of Growth</div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
/* Hero */
.loc-hero {
  position: relative;
  padding: calc(72px + 80px) 0 80px;
  background: var(--bg);
  overflow: hidden;
}

.loc-hero-bg {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(10,10,12,0.92) 0%, rgba(10,10,12,0.75) 100%),
    url('/images/store-interior.jpg') center/cover no-repeat;
}

.loc-hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(21,101,192,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(21,101,192,0.06) 1px, transparent 1px);
  background-size: 60px 60px;
}

.loc-hero-inner {
  position: relative;
  z-index: 2;
  max-width: 760px;
}

.loc-hero-title {
  margin-bottom: 24px;
  animation: slideInLeft 0.8s var(--ease-out) 0.2s both;
}

.loc-title-accent { color: var(--blue-light); }

.loc-hero-sub {
  font-family: var(--font-light);
  font-size: 17px;
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 40px;
  animation: fadeInUp 0.8s var(--ease-out) 0.4s both;
}

.loc-hero-pills {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
  animation: fadeInUp 0.8s var(--ease-out) 0.6s both;
}

.loc-pill {
  display: flex;
  align-items: center;
  gap: 10px;
}

.loc-pill-flag { font-size: 22px; }

.loc-pill-count {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 36px;
  line-height: 1;
  color: var(--text-primary);
}

.loc-pill-label {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--blue-light);
}

.loc-pill-divider {
  width: 1px;
  height: 40px;
  background: var(--border-light);
}

/* Banner */
.loc-banner {
  background: var(--blue-dark);
  border-top: 1px solid rgba(255,255,255,0.08);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  padding: 16px 0;
}

.loc-banner-inner {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
  justify-content: center;
}

.loc-banner-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
}

.loc-banner-item svg { opacity: 0.7; flex-shrink: 0; }

.loc-banner-link {
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  transition: color 0.2s;
}
.loc-banner-link:hover { color: white; }

.loc-banner-divider {
  width: 1px;
  height: 20px;
  background: rgba(255,255,255,0.2);
}

@media (max-width: 768px) {
  .loc-banner-divider { display: none; }
  .loc-banner-inner { gap: 16px; }
}

/* Main locator section */
.loc-section {
  padding: var(--section-pad) 0;
  background: var(--bg);
}

/* Franchise section */
.loc-franchise {
  padding: var(--section-pad) 0;
  background: var(--surface-1);
  border-top: 1px solid var(--border);
}

.loc-franchise-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}

@media (max-width: 900px) {
  .loc-franchise-inner { grid-template-columns: 1fr; }
}

.loc-franchise-sub {
  font-family: var(--font-light);
  font-size: 15px;
  color: var(--text-secondary);
  line-height: 1.75;
  max-width: 520px;
  margin-bottom: 32px;
}

.loc-franchise-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.loc-franchise-stats {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 200px;
}

@media (max-width: 900px) {
  .loc-franchise-stats {
    flex-direction: row;
    flex-wrap: wrap;
  }
}

.loc-stat {
  padding: 24px 28px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  transition: all 0.25s;
}

.loc-stat:hover { border-color: var(--blue); }

.loc-stat-value {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 36px;
  line-height: 1;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.loc-stat-label {
  font-family: var(--font-display);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--blue-light);
}
</style>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.tsx';
import MetalsShowcase from '../components/MetalsShowcase.tsx';
import ServicesSection from '../components/ServicesSection.tsx';
import WhyChooseUs from '../components/WhyChooseUs.tsx';
import CTABanner from '../components/CTABanner.tsx';
import HowItWorksSection from '../components/HowItWorksSection.tsx';
import TestimonialsSection from '../components/TestimonialsSection.tsx';

const photoStrip = [
  { src: "/images/hero-steel.jpg", label: "Steel Stock" },
  { src: "/images/steel-tubes.jpg", label: "Tubing & Pipe" },
  { src: "/images/aluminum.jpg", label: "Aluminum" },
  { src: "/images/copper.jpg", label: "Copper & Alloys" },
  { src: "/images/store-interior.jpg", label: "Our Stores" },
];

const brands = ["NASA", "Boeing", "Hollywood", "Ford", "US Military", "Lockheed", "SpaceX", "Tesla", "Caterpillar", "GE"];
---

<Layout
  title="Any Metal. Any Size. Ready Fast."
  description="Metal Supermarkets — The World's Largest Small-Quantity Metal Supplier. 130+ stores across the US, Canada & UK. 8,000+ types, grades & shapes. Cut-to-size. No minimums."
  keywords="metal supplier, steel, aluminum, copper, brass, titanium, cut to size, small quantity metals, metal store near me"
>
  <Header />
  <main>
    <HeroSection client:load />

    <!-- Photo strip -->
    <section class="photo-strip">
      {photoStrip.map((p, i) => (
        <div class={`photo-strip-item reveal delay-${i + 1}`}>
          <img src={p.src} alt={p.label} loading="lazy" class="photo-strip-img" />
          <div class="photo-strip-label">{p.label}</div>
        </div>
      ))}
    </section>

    <HowItWorksSection client:load />
    <MetalsShowcase client:load />
    <ServicesSection client:load />

    <!-- Image feature — store & team photo -->
    <section class="feature-image-section">
      <div class="feature-image-bg">
        <img src="/images/industrial.jpg" alt="Metal Supermarkets industrial facility" loading="lazy" class="feature-bg-img" />
        <div class="feature-bg-overlay"></div>
      </div>
      <div class="container feature-image-inner">
        <div class="reveal-left feature-image-content">
          <span class="section-label">Walk-In Welcome</span>
          <div class="divider"></div>
          <h2 class="display-lg feature-heading">
            130+ Stores.<br />
            <span class="feature-heading-blue">Near You.</span>
          </h2>
          <p class="feature-body">
            From coast to coast across the US, Canada, and the UK — there's always a
            Metal Supermarkets near you. Walk in, tell us what you need, and walk out
            with it cut to size. Same day.
          </p>
          <div class="feature-locations">
            <div class="feature-location-item">
              <span class="feature-location-count">80+</span>
              <span class="feature-location-label">US Stores</span>
            </div>
            <div class="feature-location-divider"></div>
            <div class="feature-location-item">
              <span class="feature-location-count">30+</span>
              <span class="feature-location-label">Canada</span>
            </div>
            <div class="feature-location-divider"></div>
            <div class="feature-location-item">
              <span class="feature-location-count">20+</span>
              <span class="feature-location-label">UK Stores</span>
            </div>
          </div>
          <a href="/locations" class="btn btn-primary" style="margin-top: 32px;">
            Find Your Store
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <WhyChooseUs client:load />
    <TestimonialsSection client:load />

    <!-- Trusted by brands marquee -->
    <section class="brands-section">
      <div class="container">
        <p class="brands-label">Trusted by industry leaders across every sector</p>
      </div>
      <div class="brands-scroll">
        <div class="brands-track">
          {[...brands, ...brands].map((b, i) => (
            <span key={i} class="brand-name">{b}</span>
          ))}
        </div>
      </div>
    </section>

    <CTABanner client:load />
  </main>
  <Footer />
</Layout>

<style>
/* Photo strip */
.photo-strip {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 2px;
  background: var(--bg);
}

@media (max-width: 1024px) {
  .photo-strip { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 640px) {
  .photo-strip { grid-template-columns: repeat(2, 1fr); }
}

.photo-strip-item {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/2;
  cursor: pointer;
}

.photo-strip-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(0.5) brightness(0.7);
  transition: all 0.5s var(--ease);
}

.photo-strip-item:hover .photo-strip-img {
  filter: saturate(0.9) brightness(0.85);
  transform: scale(1.05);
}

.photo-strip-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 12px;
  background: linear-gradient(to top, rgba(10,10,12,0.9) 0%, transparent 100%);
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--silver);
  transform: translateY(100%);
  transition: transform 0.3s var(--ease);
}

.photo-strip-item:hover .photo-strip-label {
  transform: translateY(0);
}

/* Feature image section */
.feature-image-section {
  position: relative;
  min-height: 560px;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.feature-image-bg {
  position: absolute;
  inset: 0;
}

.feature-bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: saturate(0.3) brightness(0.4);
}

.feature-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    rgba(10,10,12,0.95) 0%,
    rgba(10,10,12,0.7) 60%,
    rgba(13,71,161,0.2) 100%
  );
}

.feature-image-inner {
  position: relative;
  z-index: 2;
  padding-top: 80px;
  padding-bottom: 80px;
}

.feature-image-content {
  max-width: 560px;
}

.feature-heading {
  margin-bottom: 16px;
  line-height: 1;
}

.feature-heading-blue { color: var(--blue-light); }

.feature-body {
  font-family: var(--font-light);
  font-size: 16px;
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 460px;
  margin-bottom: 32px;
}

.feature-locations {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}

.feature-location-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.feature-location-count {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 36px;
  line-height: 1;
  color: var(--text-primary);
}

.feature-location-label {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--blue-light);
}

.feature-location-divider {
  width: 1px;
  height: 40px;
  background: var(--border-light);
}

/* Brands */
.brands-section {
  padding: 40px 0;
  background: var(--surface-1);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}

.brands-label {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
  text-align: center;
  margin-bottom: 24px;
}

.brands-scroll { overflow: hidden; }

.brands-track {
  display: flex;
  white-space: nowrap;
  animation: marquee 20s linear infinite;
}

.brand-name {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 18px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--border-light);
  padding: 0 40px;
  flex-shrink: 0;
  transition: color 0.2s;
}

.brand-name:hover { color: var(--blue-light); }
</style>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const milestones = [
  { year: "1985", title: "Founded", desc: "Metal Supermarkets opens its first store — a new concept in metal supply." },
  { year: "1993", title: "Franchise Model", desc: "The franchise model launches, enabling rapid North American expansion." },
  { year: "2000", title: "50 Stores", desc: "Milestone 50th location opens as the brand cements its market leadership." },
  { year: "2010", title: "UK Expansion", desc: "Metal Supermarkets crosses the Atlantic, opening in the United Kingdom." },
  { year: "2018", title: "100 Stores", desc: "100 locations across the US, Canada and UK — a true global footprint." },
  { year: "Today", title: "130+ Stores", desc: "Over 130 locations and counting. The world's largest small-quantity metal supplier." },
];

const values = [
  {
    title: "Service First",
    desc: "Our product is metal. Our passion is service. Every customer, every order — we go above and beyond.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
  },
  {
    title: "Accessibility",
    desc: "No minimum orders, walk-in welcome, same-day service. Metal for everyone — from hobbyists to Fortune 500.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
  },
  {
    title: "Expertise",
    desc: "Our staff know metal inside and out. Decades of combined experience to guide every project decision.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
  },
  {
    title: "Community",
    desc: "We invest in trade schools, robotics teams, welding programs, and STEM initiatives in every community we serve.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
  },
];

const stats = [
  { value: "130+", label: "Store Locations", sub: "Across US, Canada & UK" },
  { value: "8,000+", label: "Metal Types", sub: "Types, grades & shapes" },
  { value: "40+", label: "Years in Business", sub: "Founded 1985" },
  { value: "3", label: "Countries", sub: "US, Canada, United Kingdom" },
];
---

<Layout
  title="About Us — The World's Largest Small-Quantity Metal Supplier"
  description="Metal Supermarkets — founded in 1985, now the world's largest small-quantity metal supplier with 130+ stores across the US, Canada, and UK. Our product is metal. Our passion is service."
  keywords="about metal supermarkets, metal supplier history, metal franchise, small quantity metal supplier"
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="about-hero">
      <div class="about-hero-bg"></div>
      <div class="container">
        <div class="about-hero-inner">
          <span class="section-label">Our Story</span>
          <div class="divider"></div>
          <h1 class="display-xl about-hero-title">
            Built on Metal.<br />
            <span class="text-red">Driven by Service.</span>
          </h1>
          <p class="about-hero-sub">
            Since 1985, Metal Supermarkets has been redefining what it means to buy metal.
            We're not just suppliers — we're your local metal experts, ready when you are.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="about-stats">
      <div class="container">
        <div class="about-stats-grid">
          {stats.map((stat, i) => (
            <div class={`about-stat reveal delay-${i + 1}`}>
              <div class="about-stat-value">{stat.value}</div>
              <div class="about-stat-label">{stat.label}</div>
              <div class="about-stat-sub">{stat.sub}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="about-mission">
      <div class="container about-mission-inner">
        <div class="reveal-left about-mission-text">
          <span class="section-label">Our Mission</span>
          <div class="divider"></div>
          <h2 class="display-lg">
            "The Convenience<br />
            Stores for Metal™"
          </h2>
          <p class="about-body-text">
            Metal Supermarkets was founded on a simple but powerful idea: make metal
            as easy to buy as groceries. Walk in, get what you need, walk out.
            No complicated ordering processes, no excessive minimums, no waiting weeks.
          </p>
          <p class="about-body-text">
            Today, with 130+ stores across North America and the UK, that vision
            is a reality. We serve everyone from weekend makers and artists to
            aerospace engineers and major manufacturers — with the same expertise
            and the same commitment to fast, friendly service.
          </p>
          <blockquote class="about-quote">
            "Our Product is Metal. Our Passion is Service."
          </blockquote>
        </div>
        <div class="reveal-right about-mission-visual">
          <div class="about-img-stack">
            <img src="/images/store-interior.jpg" alt="Metal Supermarkets store interior" class="about-img-main" loading="lazy" />
            <div class="about-visual-badge">
              <div class="about-visual-number">No. 1</div>
              <div class="about-visual-label">World's Largest<br />Small-Quantity<br />Metal Supplier</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="about-timeline">
      <div class="container">
        <div class="reveal">
          <span class="section-label">Company History</span>
          <div class="divider"></div>
          <h2 class="display-md" style="margin-bottom: 60px;">40 Years of Growth</h2>
        </div>

        <div class="timeline">
          {milestones.map((m, i) => (
            <div class={`timeline-item reveal delay-${Math.min(i + 1, 6)} ${i % 2 === 0 ? 'timeline-item--left' : 'timeline-item--right'}`}>
              <div class="timeline-year">{m.year}</div>
              <div class="timeline-connector">
                <div class="timeline-dot"></div>
                <div class="timeline-line"></div>
              </div>
              <div class="timeline-content">
                <h3 class="timeline-title">{m.title}</h3>
                <p class="timeline-desc">{m.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="about-values">
      <div class="container">
        <div class="about-values-header reveal">
          <span class="section-label">What We Stand For</span>
          <div class="divider"></div>
          <h2 class="display-md">Our Core Values</h2>
        </div>
        <div class="values-grid">
          {values.map((v, i) => (
            <div class={`value-card reveal delay-${i + 1}`}>
              <div class="value-icon" set:html={v.icon} />
              <h3 class="value-title">{v.title}</h3>
              <p class="value-desc">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="about-cta">
      <div class="container">
        <div class="reveal" style="text-align: center; max-width: 600px; margin: 0 auto;">
          <h2 class="display-md" style="margin-bottom: 16px;">
            Ready to Experience the Difference?
          </h2>
          <p style="font-family: var(--font-light); font-size: 16px; color: var(--text-secondary); margin-bottom: 32px; line-height: 1.7;">
            Visit your nearest Metal Supermarkets or request a quote online.
            We'd love to show you why hundreds of thousands of customers choose us.
          </p>
          <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="/locations" class="btn btn-primary" style="padding: 18px 40px;">Find Your Store</a>
            <a href="/quote" class="btn btn-outline" style="padding: 18px 32px;">Get a Quote</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
.text-red { color: var(--blue); }

/* Hero */
.about-hero {
  position: relative;
  padding: calc(72px + 80px) 0 80px;
  background: var(--bg);
  overflow: hidden;
}

.about-hero-bg {
  position: absolute;
  inset: 0;
  background: url('/images/industrial.jpg') center center / cover no-repeat;
  filter: brightness(0.15) saturate(0.5);
}

.about-hero-inner {
  position: relative; z-index: 2; max-width: 700px;
}

.about-hero-title {
  margin-bottom: 24px;
  animation: slideInLeft 0.9s var(--ease-out) 0.3s both;
}

.about-hero-sub {
  font-family: var(--font-light); font-size: 17px;
  color: var(--text-secondary); line-height: 1.7;
  max-width: 520px;
  animation: fadeInUp 0.9s var(--ease-out) 0.5s both;
}

/* Stats */
.about-stats {
  padding: 60px 0;
  background: var(--surface-1);
  border-top: 2px solid var(--blue);
  border-bottom: 1px solid var(--border);
}

.about-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
}

@media (max-width: 768px) {
  .about-stats-grid { grid-template-columns: repeat(2, 1fr); }
}

.about-stat {
  padding: 32px;
  text-align: center;
  border: 1px solid var(--border);
  background: var(--surface-2);
  transition: all 0.25s;
}

.about-stat:hover { background: var(--surface-3); }

.about-stat-value {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 52px;
  line-height: 1;
  color: var(--text-primary);
  margin-bottom: 6px;
}

.about-stat-label {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 4px;
}

.about-stat-sub {
  font-family: var(--font-light);
  font-size: 12px;
  color: var(--text-muted);
}

/* Mission */
.about-mission {
  padding: var(--section-pad) 0;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}

.about-mission-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}

@media (max-width: 1024px) {
  .about-mission-inner { grid-template-columns: 1fr; }
}

.about-body-text {
  font-family: var(--font-light);
  font-size: 15px;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 16px;
  max-width: 520px;
}

.about-quote {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 22px;
  color: var(--text-primary);
  border-left: 3px solid var(--blue);
  padding: 16px 20px;
  background: var(--surface-1);
  margin-top: 32px;
}

.about-img-stack { position: relative; padding-bottom: 20px; padding-right: 20px; }
.about-img-main {
  width: 100%; aspect-ratio: 4/3; object-fit: cover;
  border: 1px solid var(--border);
  filter: saturate(0.7); transition: filter 0.4s;
  display: block;
}
.about-img-main:hover { filter: saturate(1); }
.about-visual-badge {
  position: absolute; bottom: 0; right: 0;
  background: var(--blue-dark);
  border: 2px solid var(--blue);
  padding: 16px 20px; text-align: center;
}
.about-visual-number {
  font-family: var(--font-display); font-weight: 900;
  font-size: 40px; line-height: 1; color: white; margin-bottom: 4px;
}
.about-visual-label {
  font-family: var(--font-display); font-size: 10px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(192,210,255,0.8); line-height: 1.5;
}

/* Timeline */
.about-timeline {
  padding: var(--section-pad) 0;
  background: var(--surface-1);
  border-bottom: 1px solid var(--border);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 2px;
  max-width: 800px;
  margin: 0 auto;
}

.timeline-item {
  display: grid;
  grid-template-columns: 80px 40px 1fr;
  gap: 20px;
  align-items: start;
  padding: 24px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  transition: all 0.25s;
}

.timeline-item:hover {
  background: var(--surface-3);
  border-color: var(--blue);
}

.timeline-year {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 20px;
  color: var(--blue);
  padding-top: 2px;
  text-align: right;
}

.timeline-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--blue);
  margin: 6px auto 0;
  box-shadow: 0 0 0 4px rgba(21,101,192,0.15);
}

.timeline-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 16px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-primary);
  margin-bottom: 6px;
}

.timeline-desc {
  font-family: var(--font-light);
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* Values */
.about-values {
  padding: var(--section-pad) 0;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}

.about-values-header { margin-bottom: 48px; }

.values-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
}

@media (max-width: 1024px) {
  .values-grid { grid-template-columns: repeat(2, 1fr); }
}

.value-card {
  padding: 36px 28px;
  background: var(--surface-1);
  border: 1px solid var(--border);
  transition: all 0.25s;
}

.value-card:hover {
  background: var(--surface-2);
  border-top-color: var(--blue);
}

.value-icon {
  color: var(--blue);
  margin-bottom: 20px;
  opacity: 0.8;
}

.value-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 16px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-primary);
  margin-bottom: 12px;
}

.value-desc {
  font-family: var(--font-light);
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.65;
}

/* CTA */
.about-cta {
  padding: var(--section-pad) 0;
  background: var(--surface-1);
  border-top: 2px solid var(--blue);
}
</style>

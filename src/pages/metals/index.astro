---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const metalCategories = [
  {
    slug: "carbon-steel",
    name: "Carbon Steel",
    shortName: "Carbon Steel",
    tagline: "The Backbone of Industry",
    color: "#111114",
    accentColor: "#4A4A5A",
    grades: ["A36", "1018", "1020", "1045", "1144", "4140", "4130"],
    shapes: ["Flat Bar", "Round Bar", "Square Bar", "Hex Bar", "Angle", "Channel", "I-Beam", "Sheet", "Plate", "Tube", "Pipe"],
    desc: "The most widely used structural metal. Excellent weldability, machinability, and formability for virtually every application.",
    applications: ["Structural fabrication", "Machine parts", "Automotive", "Construction", "General manufacturing"],
    count: "250+",
  },
  {
    slug: "stainless-steel",
    name: "Stainless Steel",
    shortName: "Stainless",
    tagline: "Corrosion-Resistant. Enduring.",
    color: "#101820",
    accentColor: "#4A7C9E",
    grades: ["304", "304L", "316", "316L", "410", "416", "430", "17-4 PH", "440C", "2205 Duplex"],
    shapes: ["Sheet", "Plate", "Round Bar", "Flat Bar", "Angle", "Channel", "Tube", "Pipe", "Threaded Rod"],
    desc: "Exceptional corrosion resistance and hygienic properties. The standard for food, medical, marine, and architectural applications.",
    applications: ["Food processing", "Medical devices", "Marine hardware", "Architecture", "Chemical processing"],
    count: "180+",
  },
  {
    slug: "aluminum",
    name: "Aluminum",
    shortName: "Aluminum",
    tagline: "Light. Strong. Versatile.",
    color: "#141412",
    accentColor: "#8C8C6A",
    grades: ["1100", "2024", "3003", "5052", "6061-T6", "6063", "7050", "7075-T6"],
    shapes: ["Sheet", "Plate", "Tread Plate", "Round Bar", "Flat Bar", "Square Bar", "Angle", "Channel", "Round Tube", "Rect Tube", "Pipe"],
    desc: "Lightweight yet strong with exceptional corrosion resistance. The choice for aerospace, automotive, and architectural applications.",
    applications: ["Aerospace structures", "Automotive parts", "Marine hardware", "Electronics", "Architecture"],
    count: "120+",
  },
  {
    slug: "copper",
    name: "Copper",
    shortName: "Copper",
    tagline: "Unmatched Conductivity.",
    color: "#180E08",
    accentColor: "#B87333",
    grades: ["C110", "C101", "C102", "C145"],
    shapes: ["Sheet", "Plate", "Round Bar", "Flat Bar", "Square Bar", "Tube"],
    desc: "Highest electrical and thermal conductivity of any common metal. Essential for electrical systems, HVAC, and plumbing.",
    applications: ["Electrical bus bars", "HVAC systems", "Plumbing", "Welding fixtures", "Commutators"],
    count: "40+",
  },
  {
    slug: "brass",
    name: "Brass",
    shortName: "Brass",
    tagline: "Machinability. Elegance.",
    color: "#121000",
    accentColor: "#CFB53B",
    grades: ["C260 (Cartridge)", "C360 (Free-Machining)", "C385", "C464 (Naval)"],
    shapes: ["Round Bar", "Flat Bar", "Square Bar", "Hex Bar", "Sheet", "Plate", "Tube"],
    desc: "Excellent machinability, attractive gold appearance, and good corrosion resistance. The machinist's metal of choice.",
    applications: ["Precision machined parts", "Fittings & valves", "Decorative hardware", "Musical instruments", "Ammunition"],
    count: "60+",
  },
  {
    slug: "bronze",
    name: "Bronze",
    shortName: "Bronze",
    tagline: "Strength. Wear Resistance.",
    color: "#100C04",
    accentColor: "#8B6914",
    grades: ["C932 SAE660 (Bearing)", "C954 (Aluminum Bronze)", "C220 (Commercial)", "C630"],
    shapes: ["Round Bar", "Flat Bar", "Square Bar", "Round Tube"],
    desc: "Superior wear resistance and self-lubricating properties. The premier choice for bearings, bushings, and high-load applications.",
    applications: ["Bearings & bushings", "Marine hardware", "Pump components", "Architectural bronze", "Industrial machinery"],
    count: "30+",
  },
  {
    slug: "tool-steel",
    name: "Tool Steel",
    shortName: "Tool Steel",
    tagline: "Hardness. Precision.",
    color: "#0C0C0C",
    accentColor: "#606060",
    grades: ["A2", "D2", "H13", "M2", "O1", "S7", "W1"],
    shapes: ["Round Bar", "Flat Bar", "Square Bar", "Plate", "Drill Rod", "Ground Flat Stock"],
    desc: "Exceptional hardness, wear resistance, and ability to retain a cutting edge. Engineered for dies, punches, and precision tooling.",
    applications: ["Dies & punches", "Cutting tools", "Injection molds", "Drill bits", "Gauges"],
    count: "40+",
  },
  {
    slug: "titanium",
    name: "Titanium",
    shortName: "Titanium",
    tagline: "Aerospace-Grade Strength.",
    color: "#080E16",
    accentColor: "#3A5F8F",
    grades: ["Grade 2 (CP)", "Grade 5 (Ti-6Al-4V)", "Grade 23 (ELI)"],
    shapes: ["Round Bar", "Flat Bar", "Sheet", "Plate", "Tube"],
    desc: "Extraordinary strength-to-weight ratio with exceptional corrosion resistance. The material of choice for aerospace and medical.",
    applications: ["Aerospace structures", "Medical implants", "Marine hardware", "Chemical processing", "Motorsport"],
    count: "20+",
  },
  {
    slug: "alloy-steel",
    name: "Alloy Steel",
    shortName: "Alloy Steel",
    tagline: "Enhanced. Engineered.",
    color: "#0C0C18",
    accentColor: "#555080",
    grades: ["4130", "4140", "4340", "8620", "52100"],
    shapes: ["Round Bar", "Flat Bar", "Square Bar", "Hex Bar", "Plate", "Tube"],
    desc: "Carbon steel enhanced with alloying elements for superior strength, toughness, hardenability, and wear resistance.",
    applications: ["Gears & shafts", "Aerospace fasteners", "Hydraulic components", "Defense parts", "Oil & gas"],
    count: "80+",
  },
  {
    slug: "hot-rolled-steel",
    name: "Hot Rolled Steel",
    shortName: "Hot Rolled",
    tagline: "Structural. Economical.",
    color: "#0A0A0A",
    accentColor: "#3A3A3A",
    grades: ["A36", "A572 Gr50", "A992"],
    shapes: ["Angle", "Channel", "I-Beam", "Wide Flange", "Flat Bar", "Sheet", "Plate"],
    desc: "The workhorse of structural steel. Economical, weldable, and available in every structural shape for construction and fabrication.",
    applications: ["Steel structures", "Building frames", "Bridges", "Equipment frames", "General fabrication"],
    count: "100+",
  },
  {
    slug: "cold-rolled-steel",
    name: "Cold Rolled Steel",
    shortName: "Cold Rolled",
    tagline: "Smooth. Precise.",
    color: "#0C0C14",
    accentColor: "#404060",
    grades: ["1008", "1018", "1020"],
    shapes: ["Sheet", "Strip", "Flat Bar", "Round Bar", "Square Bar"],
    desc: "Tighter tolerances, smoother surface finish, and higher strength than hot rolled. Superior for precision parts and sheet metal work.",
    applications: ["Precision parts", "Sheet metal work", "Automotive panels", "Appliances", "Enclosures"],
    count: "50+",
  },
  {
    slug: "nickel-alloys",
    name: "Nickel Alloys",
    shortName: "Nickel",
    tagline: "Extreme Environments.",
    color: "#0A1018",
    accentColor: "#2A5070",
    grades: ["Inconel 625", "Inconel 718", "Hastelloy C276", "Monel 400", "Nickel 200"],
    shapes: ["Round Bar", "Sheet", "Plate", "Tube"],
    desc: "Engineered for extreme temperature, pressure, and corrosive environments where other metals fail completely.",
    applications: ["Jet engines", "Chemical reactors", "Offshore oil & gas", "Nuclear", "Heat exchangers"],
    count: "30+",
  },
];

const shapes = [
  { name: "Bar Stock", icon: "▬", desc: "Round, flat, square, hex — all metals, custom lengths" },
  { name: "Sheet & Plate", icon: "▪", desc: "Cut to your exact dimensions, any thickness" },
  { name: "Tube & Pipe", icon: "○", desc: "Round, square, rectangular — structural and mechanical" },
  { name: "Structural", icon: "⌐", desc: "Angle, channel, I-beam, wide flange and more" },
  { name: "Extrusions", icon: "═", desc: "Custom aluminum profiles and standard shapes" },
  { name: "Specialty", icon: "◇", desc: "Drill rod, ground flat stock, tread plate, perforated" },
];
---

<Layout
  title="Buy Metal — 8,000+ Types, Grades & Shapes"
  description="Shop Metal Supermarkets' full inventory. Steel, aluminum, copper, brass, titanium, tool steel, nickel alloys and more. All cut to size. No minimums. Same day."
  keywords="buy metal, steel, aluminum, copper, brass, titanium, stainless steel, tool steel, metal supplier, cut to size metal"
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="metals-hero">
      <div class="metals-hero-bg"></div>
      <div class="container">
        <div class="metals-hero-inner">
          <span class="section-label">Metal Inventory</span>
          <div class="divider"></div>
          <h1 class="display-xl metals-hero-title">
            Any Metal.<br />
            <span class="metals-title-accent">Any Size.</span>
          </h1>
          <p class="metals-hero-sub">
            8,000+ types, grades, and shapes. Cut to your exact dimensions.
            In stock now at 130+ locations — no minimums, no waiting.
          </p>
          <div class="metals-hero-tags">
            {["Steel", "Aluminum", "Copper", "Brass", "Bronze", "Titanium", "Tool Steel", "Nickel Alloys"].map(t => (
              <span class="metals-hero-tag">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Shapes bar -->
    <section class="shapes-bar">
      <div class="container">
        <div class="shapes-grid">
          {shapes.map((s) => (
            <div class="shape-item">
              <span class="shape-icon">{s.icon}</span>
              <div>
                <div class="shape-name">{s.name}</div>
                <div class="shape-desc">{s.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Metal catalog grid -->
    <section class="metals-catalog">
      <div class="container">
        <div class="catalog-header reveal">
          <span class="section-label">Browse by Metal</span>
          <div class="divider"></div>
          <h2 class="display-md">Choose Your Material</h2>
          <p class="catalog-sub">
            Click any metal below to explore grades, shapes, applications, and properties.
            All available cut to size with no minimum order.
          </p>
        </div>

        <div class="catalog-grid">
          {metalCategories.map((metal, i) => (
            <a href={`/metals/${metal.slug}`} class={`metal-card reveal delay-${Math.min(i + 1, 6)}`} style={`--card-accent: ${metal.accentColor};`}>
              <div class="metal-card-bg" style={`background: ${metal.color};`}></div>

              <div class="metal-card-body">
                <div class="metal-card-count">{metal.count} grades</div>
                <h3 class="metal-card-name">{metal.name}</h3>
                <p class="metal-card-tagline">{metal.tagline}</p>
                <p class="metal-card-desc">{metal.desc}</p>

                <div class="metal-card-grades">
                  {metal.grades.slice(0, 4).map(g => (
                    <span class="metal-grade-chip">{g}</span>
                  ))}
                  {metal.grades.length > 4 && (
                    <span class="metal-grade-more">+{metal.grades.length - 4} more</span>
                  )}
                </div>

                <div class="metal-card-shapes">
                  <span class="metal-shapes-label">Shapes: </span>
                  {metal.shapes.slice(0, 3).join(" · ")}
                  {metal.shapes.length > 3 && ` · +${metal.shapes.length - 3} more`}
                </div>
              </div>

              <div class="metal-card-footer">
                <span class="metal-card-cta">
                  Explore {metal.shortName}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="metals-cta">
      <div class="container">
        <div class="reveal" style="text-align:center; max-width:640px; margin:0 auto;">
          <h2 class="display-md" style="margin-bottom:20px;">Don't See What You Need?</h2>
          <p style="font-family:var(--font-light); font-size:16px; color:var(--text-secondary); line-height:1.7; margin-bottom:36px;">
            With 8,000+ metals in stock, we probably have it. Call your nearest store or
            request a quote online and we'll source it for you.
          </p>
          <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
            <a href="/quote" class="btn btn-primary" style="padding:18px 40px;">Get a Quote</a>
            <a href="tel:18883179980" class="btn btn-outline" style="padding:18px 32px;">Call 1-888-317-9980</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
.metals-hero {
  position: relative;
  padding: calc(72px + 80px) 0 80px;
  background: var(--bg);
  overflow: hidden;
}
.metals-hero-bg {
  position: absolute; inset: 0;
  background:
    linear-gradient(rgba(10,10,12,0.90) 0%, rgba(10,10,12,0.70) 100%),
    url('/images/hero-steel.jpg') center/cover no-repeat;
}
.metals-hero-bg::after {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(21,101,192,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(21,101,192,0.05) 1px, transparent 1px);
  background-size: 60px 60px;
}
.metals-hero-inner { position: relative; z-index: 2; max-width: 760px; }
.metals-hero-title {
  margin-bottom: 20px;
  animation: slideInLeft 0.8s var(--ease-out) 0.2s both;
}
.metals-title-accent { color: var(--blue-light); }
.metals-hero-sub {
  font-family: var(--font-light); font-size: 17px;
  color: var(--text-secondary); line-height: 1.7;
  max-width: 540px; margin-bottom: 32px;
  animation: fadeInUp 0.8s var(--ease-out) 0.4s both;
}
.metals-hero-tags {
  display: flex; flex-wrap: wrap; gap: 8px;
  animation: fadeInUp 0.8s var(--ease-out) 0.6s both;
}
.metals-hero-tag {
  font-family: var(--font-display); font-size: 11px;
  font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  padding: 5px 12px;
  background: rgba(21,101,192,0.1);
  border: 1px solid rgba(21,101,192,0.2);
  color: var(--blue-light); border-radius: 2px;
}

.shapes-bar {
  padding: 48px 0;
  background: var(--surface-1);
  border-top: 2px solid var(--blue);
  border-bottom: 1px solid var(--border);
}
.shapes-grid {
  display: grid; grid-template-columns: repeat(6, 1fr); gap: 24px;
}
@media (max-width: 1024px) { .shapes-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 640px)  { .shapes-grid { grid-template-columns: repeat(2, 1fr); } }
.shape-item { display: flex; align-items: flex-start; gap: 12px; }
.shape-icon { font-size: 20px; color: var(--blue); margin-top: 2px; flex-shrink: 0; }
.shape-name { font-family: var(--font-display); font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-primary); margin-bottom: 3px; }
.shape-desc { font-family: var(--font-light); font-size: 11px; color: var(--text-muted); line-height: 1.5; }

.metals-catalog { padding: var(--section-pad) 0; background: var(--bg); }
.catalog-header { margin-bottom: 48px; }
.catalog-sub { font-family: var(--font-light); font-size: 15px; color: var(--text-secondary); line-height: 1.7; max-width: 560px; margin-top: 16px; }
.catalog-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
}
@media (max-width: 1100px) { .catalog-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px)  { .catalog-grid { grid-template-columns: 1fr; } }

.metal-card {
  position: relative; overflow: hidden;
  display: flex; flex-direction: column;
  text-decoration: none;
  border: 1px solid var(--border);
  transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  min-height: 300px;
}
.metal-card:hover { border-color: var(--card-accent, var(--blue)); transform: translateY(-3px); z-index: 2; }
.metal-card-bg { position: absolute; inset: 0; opacity: 0.95; transition: opacity 0.25s; }
.metal-card:hover .metal-card-bg { opacity: 1; }

.metal-card-body { position: relative; z-index: 1; padding: 28px 24px 16px; flex: 1; }
.metal-card-count { font-family: var(--font-display); font-size: 10px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px; }
.metal-card-name { font-family: var(--font-display); font-weight: 900; font-size: 26px; line-height: 1; text-transform: uppercase; letter-spacing: 0.02em; color: var(--text-primary); margin-bottom: 4px; }
.metal-card-tagline { font-family: var(--font-display); font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--card-accent, var(--blue-light)); margin-bottom: 16px; }
.metal-card-desc { font-family: var(--font-light); font-size: 13px; color: var(--text-secondary); line-height: 1.6; margin-bottom: 20px; }
.metal-card-grades { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 12px; }
.metal-grade-chip { font-family: var(--font-display); font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 3px 8px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: var(--text-secondary); border-radius: 2px; }
.metal-grade-more { font-family: var(--font-display); font-size: 10px; font-weight: 600; color: var(--text-muted); padding: 3px 8px; }
.metal-card-shapes { font-family: var(--font-light); font-size: 11px; color: var(--text-muted); line-height: 1.5; }
.metal-shapes-label { font-family: var(--font-display); font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }

.metal-card-footer { position: relative; z-index: 1; padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.08); background: rgba(0,0,0,0.2); }
.metal-card-cta { display: flex; align-items: center; gap: 8px; font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--card-accent, var(--blue-light)); transition: gap 0.2s; }
.metal-card:hover .metal-card-cta { gap: 12px; }

.metals-cta { padding: var(--section-pad) 0; background: var(--surface-1); border-top: 1px solid var(--border); }
</style>

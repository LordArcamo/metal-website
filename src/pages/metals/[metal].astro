        { label: "Melting Point", value: "1,425–1,540°C" },
        { label: "Weldability", value: "Excellent (low C)" },
        { label: "Machinability", value: "Good to Excellent" },
      ],
      seoDesc: "Buy carbon steel cut to size. A36, 1018, 1045, 4140 and more. Same-day service at 130+ locations across the US, Canada & UK.",

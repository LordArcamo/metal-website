const { metal } = Astro.props;
---

<Layout
  title={`${metal.name} — Grades, Shapes & Cut-to-Size`}
  description={metal.seoDesc}
  keywords={`${metal.name.toLowerCase()}, ${metal.grades.map(g => g.grade.toLowerCase()).join(', ')}, cut to size ${metal.name.toLowerCase()}, metal supplier`}
>
  <Header />
  <main>

    <!-- Breadcrumb + hero -->
    <section class="metal-page-hero">
      <div class="metal-page-bg"></div>
      <div class="container">
        <div class="metal-breadcrumb">
          <a href="/" class="metal-breadcrumb-link">Home</a>
          <span class="metal-breadcrumb-sep">›</span>
          <a href="/metals" class="metal-breadcrumb-link">Metals</a>
          <span class="metal-breadcrumb-sep">›</span>
          <span class="metal-breadcrumb-current">{metal.name}</span>
        </div>
        <div class="metal-page-inner">
          <span class="section-label">Material Guide</span>
          <div class="divider"></div>
          <h1 class="display-xl metal-page-title">{metal.name}</h1>
          <p class="metal-page-tagline">{metal.tagline}</p>
          <p class="metal-page-desc">{metal.desc}</p>
          <div class="metal-page-actions">
            <a href="/quote" class="btn btn-primary">Get a Quote</a>
            <a href="/locations" class="btn btn-outline">Find a Store</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick properties -->
    <section class="metal-props">
      <div class="container">
        <div class="metal-props-grid">
          {metal.properties.map((p) => (
            <div class="metal-prop">
              <div class="metal-prop-label">{p.label}</div>
              <div class="metal-prop-value">{p.value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Grades -->
    <section class="metal-grades-section">
      <div class="container">
        <div class="reveal" style="margin-bottom:40px;">
          <span class="section-label">Available Grades</span>
          <div class="divider"></div>
          <h2 class="display-md">Grades We Stock</h2>
        </div>
        <div class="metal-grades-grid">
          {metal.grades.map((g, i) => (
            <div class={`metal-grade-card reveal delay-${Math.min(i + 1, 6)}`}>
              <div class="metal-grade-name">{g.grade}</div>
              <p class="metal-grade-desc">{g.desc}</p>
              <div class="metal-grade-apps">
                <span class="metal-grade-apps-label">Applications: </span>
                {g.applications}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Shapes -->
    <section class="metal-shapes-section">
      <div class="container">
        <div class="reveal" style="margin-bottom:40px;">
          <span class="section-label">Available Forms</span>
          <div class="divider"></div>
          <h2 class="display-md">Shapes & Profiles</h2>
          <p style="font-family:var(--font-light); font-size:15px; color:var(--text-secondary); margin-top:12px; line-height:1.7; max-width:520px;">
            All shapes are available cut to your exact dimensions with no minimum order.
            Tolerances to ±0.015".
          </p>
        </div>
        <div class="metal-shapes-list">
          {metal.shapes.map((s) => (
            <div class="metal-shape-item reveal">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="metal-shape-check"><polyline points="20 6 9 17 4 12"/></svg>

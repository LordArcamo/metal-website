---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const steps = [
  { num: "01", title: "Inquiry", desc: "Fill out the franchise inquiry form. Our development team will reach out within 48 hours." },
  { num: "02", title: "Discovery Call", desc: "A 30-minute call with our franchise development team to learn about your goals and our model." },
  { num: "03", title: "Application", desc: "Complete the formal franchise application. We review your background, financials, and fit." },
  { num: "04", title: "Discovery Day", desc: "Visit a store and our headquarters. Meet the team, see operations, ask every question." },
  { num: "05", title: "Agreement", desc: "Review and sign the franchise agreement with your legal counsel." },
  { num: "06", title: "Training", desc: "Complete our comprehensive 2-week training program covering operations, sales, and systems." },
  { num: "07", title: "Grand Opening", desc: "We support your launch with marketing, inventory setup, and hands-on opening-week assistance." },
];

const supports = [
  { title: "Site Selection", desc: "Our team helps identify and evaluate optimal locations using demographic and market data." },
  { title: "Store Buildout", desc: "Proven store design and layout blueprints. We guide you through every step of the buildout." },
  { title: "Inventory Systems", desc: "Access to our supply chain, preferred vendor pricing, and proprietary inventory management software." },
  { title: "Marketing Support", desc: "National brand campaigns, local marketing playbooks, digital presence management, and co-op advertising." },
  { title: "Training Programs", desc: "Initial 2-week intensive + ongoing training for you and every new team member." },
  { title: "Operations Manual", desc: "A complete, battle-tested operations manual covering every aspect of running your store." },
  { title: "Franchisee Network", desc: "Join a community of 130+ owners who share best practices, insights, and support." },
  { title: "Field Support", desc: "Regional franchise business coaches visit your store regularly to drive performance." },
];

const ideals = [
  { emoji: "🎖️", title: "Veterans", desc: "Military experience translates perfectly to our operations model. Special programs available." },
  { emoji: "🔧", title: "Skilled Tradespeople", desc: "Fabricators, machinists, and metalworkers who understand the customer's needs." },
  { emoji: "💼", title: "Business Leaders", desc: "Experienced managers ready to own their career and build long-term wealth." },
  { emoji: "👨‍👩‍👧", title: "Multi-Gen Families", desc: "Build a legacy business with strong recurring revenue for future generations." },
];
---

<Layout
  title="Franchise Opportunities — Own a Metal Supermarkets"
  description="Join the world's largest small-quantity metal supplier franchise. $2.1M average annual sales, 50%+ gross margins, 35+ years of proven growth. Available markets coast-to-coast."
  keywords="metal supermarkets franchise, metal business franchise, metal supplier franchise opportunity, franchise for sale"
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="fran-hero">
      <div class="fran-hero-bg"></div>
      <div class="container">
        <div class="fran-hero-inner">
          <span class="section-label">Franchise Opportunity</span>
          <div class="divider"></div>
          <h1 class="display-xl fran-hero-title">
            Own a Metal<br />
            <span class="fran-title-accent">Supermarkets.</span>
          </h1>
          <p class="fran-hero-sub">
            Join the world's largest small-quantity metal supplier. Proven model, established brand,
            and a $189 billion industry — with coast-to-coast markets available.
          </p>
          <div class="fran-hero-actions">
            <a href="#inquiry" class="btn btn-primary fran-cta-btn">
              Request Franchise Info
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="tel:18008078755" class="btn btn-outline">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              1-800-807-8755
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Key Metrics -->
    <section class="fran-metrics">
      <div class="container">
        <div class="fran-metrics-grid">
          <div class="fran-metric reveal delay-1">
            <div class="fran-metric-value">$2.1M</div>
            <div class="fran-metric-label">Avg Annual Sales</div>
            <div class="fran-metric-sub">Per store, 2025 data</div>
          </div>
          <div class="fran-metric reveal delay-2">
            <div class="fran-metric-value">50%+</div>
            <div class="fran-metric-label">Avg Gross Margin</div>
            <div class="fran-metric-sub">Industry-leading margins</div>
          </div>
          <div class="fran-metric reveal delay-3">
            <div class="fran-metric-value">$189B</div>
            <div class="fran-metric-label">Industry Size</div>
            <div class="fran-metric-sub">Metal distribution market</div>
          </div>
          <div class="fran-metric reveal delay-4">
            <div class="fran-metric-value">35+</div>
            <div class="fran-metric-label">Years of Growth</div>
            <div class="fran-metric-sub">Consistent sales history</div>
          </div>
          <div class="fran-metric reveal delay-5">
            <div class="fran-metric-value">300K+</div>
            <div class="fran-metric-label">Loyal Customers</div>
            <div class="fran-metric-sub">Across the network</div>
          </div>
          <div class="fran-metric reveal delay-6">
            <div class="fran-metric-value">130+</div>
            <div class="fran-metric-label">Locations Open</div>
            <div class="fran-metric-sub">US, Canada & UK</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why own section -->
    <section class="fran-why">
      <div class="container fran-why-inner">
        <div class="reveal-left">
          <span class="section-label">Why Metal Supermarkets</span>
          <div class="divider"></div>
          <h2 class="display-md fran-why-title">
            A Proven Model in a<br />Recession-Resistant Industry
          </h2>
          <p class="fran-body">
            Metal is essential. It doesn't go out of style, it doesn't get disrupted by apps, and it
            can't be 3D-printed fast enough to replace what we do. Metal Supermarkets fills a
            permanent gap in the market — small quantities, cut to size, available now.
          </p>
          <p class="fran-body">
            Our franchise model has been refined over 35+ years. The operations, supply chain,
            marketing, training, and technology are all built for you. You focus on customers
            and your team. We handle the rest.
          </p>
          <ul class="fran-points">
            <li>No manufacturing — pure distribution and service</li>
            <li>Low inventory risk with just-in-time supply chain</li>
            <li>Recurring B2B and B2C customer base</li>
            <li>Proven marketing systems and national brand recognition</li>
            <li>Exclusive territory protection</li>
          </ul>
        </div>
        <div class="reveal-right fran-why-img-wrap">
          <img src="/images/industrial.jpg" alt="Metal Supermarkets store operations" class="fran-why-img" loading="lazy" />
          <div class="fran-why-badge">
            <div class="fran-badge-text">No. 1</div>
            <div class="fran-badge-sub">World's Largest<br />Small-Quantity<br />Metal Supplier</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Support pillars -->
    <section class="fran-support">
      <div class="container">
        <div class="fran-support-header reveal">
          <span class="section-label">Franchisee Support</span>
          <div class="divider"></div>
          <h2 class="display-md">We Set You Up to Win</h2>
        </div>
        <div class="fran-support-grid">
          {supports.map((s, i) => (
            <div class={`fran-support-card reveal delay-${Math.min(i + 1, 6)}`}>
              <div class="fran-support-num">{String(i + 1).padStart(2, "0")}</div>
              <h3 class="fran-support-title">{s.title}</h3>
              <p class="fran-support-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Ideal franchisee -->
    <section class="fran-ideal">
      <div class="container">
        <div class="fran-ideal-header reveal">
          <span class="section-label">Who We're Looking For</span>
          <div class="divider"></div>
          <h2 class="display-md">The Ideal Franchise Owner</h2>
          <p class="fran-ideal-sub">
            You don't need a background in metal. You need drive, people skills, and the ambition
            to build something real. We'll teach you everything else.
          </p>
        </div>
        <div class="fran-ideal-grid">
          {ideals.map((item, i) => (
            <div class={`fran-ideal-card reveal delay-${i + 1}`}>
              <div class="fran-ideal-emoji">{item.emoji}</div>
              <h3 class="fran-ideal-title">{item.title}</h3>
              <p class="fran-ideal-desc">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process steps -->
    <section class="fran-process">
      <div class="container">
        <div class="fran-process-header reveal">
          <span class="section-label">The Process</span>
          <div class="divider"></div>
          <h2 class="display-md">From Inquiry to Grand Opening</h2>
        </div>
        <div class="fran-steps">
          {steps.map((step, i) => (
            <div class={`fran-step reveal delay-${Math.min(i + 1, 6)}`}>
              <div class="fran-step-num">{step.num}</div>
              <div class="fran-step-content">
                <h3 class="fran-step-title">{step.title}</h3>
                <p class="fran-step-desc">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Inquiry form -->
    <section class="fran-inquiry" id="inquiry">
      <div class="container">
        <div class="fran-inquiry-inner reveal">
          <div class="fran-inquiry-text">
            <span class="section-label">Get Started</span>
            <div class="divider"></div>
            <h2 class="display-md">Request Franchise Information</h2>
            <p class="fran-inquiry-sub">
              Fill out the form and our franchise development team will contact you within 48 hours.
              There's no obligation — just a conversation.
            </p>
            <div class="fran-contact-direct">
              <a href="tel:18008078755" class="fran-contact-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                Call: 1-800-807-8755
              </a>
            </div>
          </div>
          <form class="fran-form" action="/thank-you" method="get">
            <div class="fran-form-row">
              <div class="fran-form-group">
                <label class="fran-label">First Name *</label>
                <input type="text" class="fran-input" placeholder="John" required />
              </div>
              <div class="fran-form-group">
                <label class="fran-label">Last Name *</label>
                <input type="text" class="fran-input" placeholder="Smith" required />
              </div>
            </div>
            <div class="fran-form-group">
              <label class="fran-label">Email Address *</label>
              <input type="email" class="fran-input" placeholder="john@email.com" required />
            </div>
            <div class="fran-form-group">
              <label class="fran-label">Phone Number *</label>
              <input type="tel" class="fran-input" placeholder="(555) 000-0000" required />
            </div>
            <div class="fran-form-row">
              <div class="fran-form-group">
                <label class="fran-label">City *</label>
                <input type="text" class="fran-input" placeholder="Your city" required />
              </div>
              <div class="fran-form-group">
                <label class="fran-label">State/Province *</label>
                <input type="text" class="fran-input" placeholder="State or province" required />
              </div>
            </div>
            <div class="fran-form-group">
              <label class="fran-label">Liquid Capital Available</label>
              <select class="fran-input fran-select">
                <option value="">Select range...</option>
                <option>Under $100,000</option>
                <option>$100,000 – $200,000</option>
                <option>$200,000 – $300,000</option>
                <option>$300,000 – $500,000</option>
                <option>Over $500,000</option>
              </select>
            </div>
            <div class="fran-form-group">
              <label class="fran-label">Tell Us About Yourself</label>
              <textarea class="fran-input fran-textarea" rows={4} placeholder="Background, why you're interested, questions..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary fran-submit">
              Submit Inquiry
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
            <p class="fran-disclaimer">
              * Note: Franchise not available in all states. CA, HI, IL, IN, MD, and others require additional registration.
            </p>
          </form>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
/* Hero */
.fran-hero {
  position: relative;
  padding: calc(72px + 80px) 0 80px;
  overflow: hidden;
  background: var(--bg);
}
.fran-hero-bg {
  position: absolute; inset: 0;
  background:
    linear-gradient(rgba(10,10,12,0.88) 0%, rgba(13,71,161,0.15) 100%),
    url('/images/workshop.jpg') center/cover no-repeat;
}
.fran-hero-bg::after {
  content: '';
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(21,101,192,0.07) 1px, transparent 1px),
    linear-gradient(90deg, rgba(21,101,192,0.07) 1px, transparent 1px);
  background-size: 60px 60px;
}
.fran-hero-inner { position: relative; z-index: 2; max-width: 740px; }
.fran-hero-title {
  margin-bottom: 24px;
  animation: slideInLeft 0.8s var(--ease-out) 0.2s both;
}
.fran-title-accent { color: var(--blue-light); }
.fran-hero-sub {
  font-family: var(--font-light); font-size: 17px;
  color: var(--text-secondary); line-height: 1.7;
  max-width: 540px; margin-bottom: 40px;
  animation: fadeInUp 0.8s var(--ease-out) 0.4s both;
}
.fran-hero-actions {
  display: flex; gap: 16px; flex-wrap: wrap;
  animation: fadeInUp 0.8s var(--ease-out) 0.6s both;
}
.fran-cta-btn { padding: 18px 40px; }

/* Metrics */
.fran-metrics {
  background: var(--surface-1);
  border-top: 2px solid var(--blue);
  border-bottom: 1px solid var(--border);
  padding: 60px 0;
}
.fran-metrics-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 2px;
}
@media (max-width: 1024px) { .fran-metrics-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 640px)  { .fran-metrics-grid { grid-template-columns: repeat(2, 1fr); } }

.fran-metric {
  padding: 32px 20px;
  text-align: center;
  background: var(--surface-2);
  border: 1px solid var(--border);
  transition: all 0.25s;
}
.fran-metric:hover { border-color: var(--blue); background: var(--surface-3); }
.fran-metric-value {
  font-family: var(--font-display); font-weight: 900;
  font-size: clamp(28px, 3vw, 44px); line-height: 1;
  color: var(--text-primary); margin-bottom: 6px;
}
.fran-metric-label {
  font-family: var(--font-display); font-size: 11px;
  font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--blue-light); margin-bottom: 4px;
}
.fran-metric-sub {
  font-family: var(--font-light); font-size: 11px; color: var(--text-muted);
}

/* Why section */
.fran-why {
  padding: var(--section-pad) 0;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}
.fran-why-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}
@media (max-width: 1024px) { .fran-why-inner { grid-template-columns: 1fr; } }
.fran-why-title { margin-bottom: 24px; }
.fran-body {
  font-family: var(--font-light); font-size: 15px;
  color: var(--text-secondary); line-height: 1.8;
  max-width: 520px; margin-bottom: 16px;
}
.fran-points {
  list-style: none; margin-top: 24px;
  display: flex; flex-direction: column; gap: 10px;
}
.fran-points li {
  font-family: var(--font-light); font-size: 14px;
  color: var(--text-secondary); line-height: 1.5;
  padding-left: 20px; position: relative;
}
.fran-points li::before {
  content: '→';
  position: absolute; left: 0;
  color: var(--blue); font-family: var(--font-display); font-weight: 700;
}
.fran-why-img-wrap { position: relative; }
.fran-why-img {
  width: 100%; aspect-ratio: 4/3; object-fit: cover;
  border: 1px solid var(--border); filter: saturate(0.6);
  transition: filter 0.4s;
}
.fran-why-img:hover { filter: saturate(1); }
.fran-why-badge {
  position: absolute; bottom: -20px; right: -20px;
  background: var(--blue-dark); border: 2px solid var(--blue);
  padding: 20px 24px; text-align: center;
}
@media (max-width: 1024px) { .fran-why-badge { bottom: 0; right: 0; } }
.fran-badge-text {
  font-family: var(--font-display); font-weight: 900;
  font-size: 44px; line-height: 1; color: white; margin-bottom: 4px;
}
.fran-badge-sub {
  font-family: var(--font-display); font-size: 10px;
  font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(180,210,255,0.8); line-height: 1.5;
}

/* Support */
.fran-support { padding: var(--section-pad) 0; background: var(--surface-1); border-bottom: 1px solid var(--border); }
.fran-support-header { margin-bottom: 48px; }
.fran-support-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
}
@media (max-width: 1024px) { .fran-support-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px)  { .fran-support-grid { grid-template-columns: 1fr; } }

.fran-support-card {
  padding: 32px 24px; background: var(--surface-2);
  border: 1px solid var(--border);
  transition: all 0.25s;
}
.fran-support-card:hover { border-top-color: var(--blue); background: var(--surface-3); }
.fran-support-num {
  font-family: var(--font-display); font-weight: 900;
  font-size: 40px; line-height: 1;
  color: rgba(21,101,192,0.15); margin-bottom: 16px;
}
.fran-support-title {
  font-family: var(--font-display); font-weight: 800;
  font-size: 14px; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--text-primary); margin-bottom: 10px;
}
.fran-support-desc { font-family: var(--font-light); font-size: 13px; color: var(--text-secondary); line-height: 1.65; }

/* Ideal */
.fran-ideal { padding: var(--section-pad) 0; background: var(--bg); border-bottom: 1px solid var(--border); }
.fran-ideal-header { margin-bottom: 48px; }
.fran-ideal-sub { font-family: var(--font-light); font-size: 15px; color: var(--text-secondary); line-height: 1.7; max-width: 560px; margin-top: 16px; }
.fran-ideal-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
}
@media (max-width: 1024px) { .fran-ideal-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px)  { .fran-ideal-grid { grid-template-columns: 1fr; } }
.fran-ideal-card {
  padding: 36px 28px; background: var(--surface-1);
  border: 1px solid var(--border); transition: all 0.25s;
}
.fran-ideal-card:hover { background: var(--surface-2); border-color: var(--blue); }
.fran-ideal-emoji { font-size: 36px; margin-bottom: 16px; }
.fran-ideal-title {
  font-family: var(--font-display); font-weight: 800;
  font-size: 16px; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--text-primary); margin-bottom: 10px;
}
.fran-ideal-desc { font-family: var(--font-light); font-size: 13px; color: var(--text-secondary); line-height: 1.65; }

/* Process */
.fran-process { padding: var(--section-pad) 0; background: var(--surface-1); border-bottom: 1px solid var(--border); }
.fran-process-header { margin-bottom: 48px; }
.fran-steps { display: flex; flex-direction: column; gap: 2px; max-width: 760px; }
.fran-step {
  display: grid; grid-template-columns: 56px 1fr; gap: 20px;
  padding: 24px; background: var(--surface-2);
  border: 1px solid var(--border); align-items: start;
  transition: all 0.25s;
}
.fran-step:hover { border-color: var(--blue); background: var(--surface-3); }
.fran-step-num {
  font-family: var(--font-display); font-weight: 900;
  font-size: 28px; color: var(--blue); line-height: 1; padding-top: 2px;
}
.fran-step-title {
  font-family: var(--font-display); font-weight: 800;
  font-size: 15px; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--text-primary); margin-bottom: 6px;
}
.fran-step-desc { font-family: var(--font-light); font-size: 13px; color: var(--text-secondary); line-height: 1.6; }

/* Inquiry form */
.fran-inquiry { padding: var(--section-pad) 0; background: var(--bg); }
.fran-inquiry-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 6vw, 80px); align-items: start;
}
@media (max-width: 900px) { .fran-inquiry-inner { grid-template-columns: 1fr; } }
.fran-inquiry-sub { font-family: var(--font-light); font-size: 15px; color: var(--text-secondary); line-height: 1.7; max-width: 440px; margin-bottom: 32px; }
.fran-contact-link {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-display); font-size: 14px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--blue-light); text-decoration: none; transition: color 0.2s;
}
.fran-contact-link:hover { color: white; }
.fran-form { display: flex; flex-direction: column; gap: 16px; }
.fran-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media (max-width: 640px) { .fran-form-row { grid-template-columns: 1fr; } }
.fran-form-group { display: flex; flex-direction: column; gap: 6px; }
